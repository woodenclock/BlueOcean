# RMF2 demo stack — ports, compose profile, spellbook paths (single source of truth)
#
# Docker Compose: symlink as `.env` or pass explicitly:
#   docker compose --env-file config/config.env up --build
#
# Spellbook / host adapters: paths below are relative to repo root.
#   source .env                    # from repo root
#   source autoxing_bridge/spellbook/activate_autoxing.sh   # loads this file

# Default profile: plain `docker compose up` starts the dry-run stack.
# Real physical demo: `docker compose --env-file config/config.env --env-file config/config-real.env up --build`.
COMPOSE_PROFILES=dry-run
COMPOSE_PROJECT_NAME=rmf2_demo_gametl-dry-run

MQTT_PORT=1883
AMQP_PORT=5672
AMQP_MGMT_PORT=15672
SCHEDULER_PORT=8089
TASK_ORCHESTRATOR_PORT=2727
VDA5050_PORT=8000
UI_PORT=3000

# Spellbook commands/ dirs (relative to repo root)
AUTOXING_SPELLBOOK_DIR=src/vda5050_core_gametl/vda5050_core_py/demo-june-blue-ocean/autoxing_bridge/spellbook/commands
REEMAN_SPELLBOOK_DIR=src/vda5050_core_gametl/vda5050_core_py/demo-june-blue-ocean/reeman_bridge/spellbook/commands

# Robot IPs (optional — override spellbook credentials/CONSTANTS.yml when set)
# Autoxing REST: http://host:port  (spellbook also accepts AUTOXING_ROBOT_IP=host:port)
AUTOXING_BASE_URL=http://192.168.68.64:8090
# Reeman REST: host or host:port  (or REEMAN_BASE_URL=http://host)
REEMAN_ROBOT_IP=192.168.68.62

# Real-demo VDA5050 map id (master frame = AutoXing onboard map)
VDA5050_MAP_ID=From Mapping 40
AUTOXING_ONBOARD_MAP_ID=27
AUTOXING_ONBOARD_MAP_NAME=From Mapping 40
REEMAN_ONBOARD_MAP_NAME=886d396851aa60b150419998b0a56e59