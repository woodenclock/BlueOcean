# RMF2 demo stack — ports, compose profile, map floor, spellbook paths.
# SINGLE SOURCE OF TRUTH for stack-level config. Copy this template to `.env`:
#
#   cp .env.sample .env
#
# Docker Compose auto-loads `.env` at repo root (no --env-file needed).
# Spellbook / host adapters also read it:
#   source .env                    # from repo root
#   source autoxing_bridge/spellbook/activate_autoxing.sh   # loads this file

# Default profile: plain `docker compose up` starts the dry-run stack.
# Real physical demo: `docker compose --profile real-demo up --build`
COMPOSE_PROFILES=real-demo

# Active map floor — AND the VDA5050 master-frame map id. This single value is
# both the AutoXing master onboard map name AND the floor dir name: the master
# serves maps/<VDA5050_MAP_ID>/. Each floor dir uses the same normalized
# filenames (robots.yaml, map_transforms.yaml, real.layout.yaml,
# dry_run.layout.yaml, master.image.png/.yaml). Switch floors by changing it:
#   AMAV-X    maps/AMAV-X/   AMAV-X master frame (default real demo)
#   l1-artc   maps/l1-artc/  synthetic dry-run grid + ARTC real floor
VDA5050_MAP_ID=AMAV-X

MQTT_PORT=1883
AMQP_PORT=5672
AMQP_MGMT_PORT=15672
SCHEDULER_PORT=8089
TASK_ORCHESTRATOR_PORT=2727
VDA5050_PORT=8000
UI_PORT=3000
# Internal nginx listen port inside the dashboard container (host maps UI_PORT -> NGINX_PORT)
NGINX_PORT=80

# Spellbook commands/ dirs (relative to repo root).
# NOTE: spellbook dirs are per-MANUFACTURER (shared by every robot of that type),
# not per-instance, and are read host-side by _spellbook_path.py with no compose
# mapping layer — so they stay generic (no _1_/_2_ numbering).
AUTOXING_SPELLBOOK_DIR=src/vda5050_core_gametl/vda5050_core_py/demo-june-blue-ocean/autoxing_bridge/spellbook
REEMAN_SPELLBOOK_DIR=src/vda5050_core_gametl/vda5050_core_py/demo-june-blue-ocean/reeman_bridge/spellbook

# Per-robot config (REST host `endpoint`, onboard map id/name) lives in
# maps/<VDA5050_MAP_ID>/robots.yaml — the single source of truth, served by the
# master /robots. The scheduler, adapters, and master jack-control all read it
# from there, so there are no per-robot IP/map env vars here.
