    {
      "description": "Store task for SNS1",
      "payload": {
        "type": "TaskRequest",
        "id": "urn:ngsild:Task:task_Store001:TaskRequest",
        "task_type": "Store",
        "task_command": "START",
        "asset_id": "SNS1",
        "task_params": {
          "area_id": "Incoming1"
